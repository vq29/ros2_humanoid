<?xml version="1.0"?>
<!-- 
  Humanoid Robot Arm - 6-DOF Serial Manipulator
  Shoulder: pitch, roll, yaw
  Elbow: pitch
  Wrist: pitch, roll
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="humanoid_arm" params="prefix parent_link *origin">

    <!-- ==================== MATERIALS ==================== -->
    <material name="${prefix}arm_dark_grey">
      <color rgba="0.3 0.3 0.3 1.0"/>
    </material>
    <material name="${prefix}arm_silver">
      <color rgba="0.75 0.75 0.75 1.0"/>
    </material>
    <material name="${prefix}arm_blue">
      <color rgba="0.2 0.4 0.8 1.0"/>
    </material>

    <!-- ==================== LINK PROPERTIES ==================== -->
    <xacro:property name="shoulder_radius" value="0.05"/>
    <xacro:property name="upper_arm_length" value="0.25"/>
    <xacro:property name="upper_arm_radius" value="0.035"/>
    <xacro:property name="forearm_length" value="0.22"/>
    <xacro:property name="forearm_radius" value="0.03"/>
    <xacro:property name="wrist_radius" value="0.025"/>
    <xacro:property name="wrist_length" value="0.08"/>

    <!-- ==================== SHOULDER PITCH (Joint 1) ==================== -->
    <joint name="${prefix}shoulder_pitch_joint" type="revolute">
      <xacro:insert_block name="origin"/>
      <parent link="${parent_link}"/>
      <child link="${prefix}shoulder_pitch_link"/>
      <axis xyz="0 1 0"/>
      <limit lower="${-pi}" upper="${pi}" effort="100.0" velocity="1.5"/>
      <dynamics damping="0.5" friction="0.1"/>
    </joint>

    <link name="${prefix}shoulder_pitch_link">
      <visual>
        <geometry>
          <sphere radius="${shoulder_radius}"/>
        </geometry>
        <material name="${prefix}arm_blue"/>
      </visual>
      <collision>
        <geometry>
          <sphere radius="${shoulder_radius}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="1.5"/>
        <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/>
      </inertial>
    </link>

    <!-- ==================== SHOULDER ROLL (Joint 2) ==================== -->
    <joint name="${prefix}shoulder_roll_joint" type="revolute">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <parent link="${prefix}shoulder_pitch_link"/>
      <child link="${prefix}shoulder_roll_link"/>
      <axis xyz="1 0 0"/>
      <limit lower="${-pi/2}" upper="${pi/2}" effort="100.0" velocity="1.5"/>
      <dynamics damping="0.5" friction="0.1"/>
    </joint>

    <link name="${prefix}shoulder_roll_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${shoulder_radius * 0.8}" length="0.04"/>
        </geometry>
        <material name="${prefix}arm_dark_grey"/>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${shoulder_radius * 0.8}" length="0.04"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.8"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
    </link>

    <!-- ==================== SHOULDER YAW (Joint 3) ==================== -->
    <joint name="${prefix}shoulder_yaw_joint" type="revolute">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <parent link="${prefix}shoulder_roll_link"/>
      <child link="${prefix}upper_arm_link"/>
      <axis xyz="0 0 1"/>
      <limit lower="${-pi}" upper="${pi}" effort="80.0" velocity="1.5"/>
      <dynamics damping="0.5" friction="0.1"/>
    </joint>

    <link name="${prefix}upper_arm_link">
      <visual>
        <origin xyz="0 0 ${-upper_arm_length/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${upper_arm_radius}" length="${upper_arm_length}"/>
        </geometry>
        <material name="${prefix}arm_silver"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${-upper_arm_length/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${upper_arm_radius}" length="${upper_arm_length}"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 ${-upper_arm_length/2}" rpy="0 0 0"/>
        <mass value="2.0"/>
        <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.002"/>
      </inertial>
    </link>

    <!-- ==================== ELBOW PITCH (Joint 4) ==================== -->
    <joint name="${prefix}elbow_pitch_joint" type="revolute">
      <origin xyz="0 0 ${-upper_arm_length}" rpy="0 0 0"/>
      <parent link="${prefix}upper_arm_link"/>
      <child link="${prefix}forearm_link"/>
      <axis xyz="0 1 0"/>
      <limit lower="0" upper="${pi * 0.85}" effort="80.0" velocity="1.5"/>
      <dynamics damping="0.3" friction="0.1"/>
    </joint>

    <link name="${prefix}forearm_link">
      <visual>
        <origin xyz="0 0 ${-forearm_length/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${forearm_radius}" length="${forearm_length}"/>
        </geometry>
        <material name="${prefix}arm_silver"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${-forearm_length/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${forearm_radius}" length="${forearm_length}"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 ${-forearm_length/2}" rpy="0 0 0"/>
        <mass value="1.5"/>
        <inertia ixx="0.006" ixy="0" ixz="0" iyy="0.006" iyz="0" izz="0.001"/>
      </inertial>
    </link>

    <!-- ==================== WRIST PITCH (Joint 5) ==================== -->
    <joint name="${prefix}wrist_pitch_joint" type="revolute">
      <origin xyz="0 0 ${-forearm_length}" rpy="0 0 0"/>
      <parent link="${prefix}forearm_link"/>
      <child link="${prefix}wrist_pitch_link"/>
      <axis xyz="0 1 0"/>
      <limit lower="${-pi/2}" upper="${pi/2}" effort="40.0" velocity="2.0"/>
      <dynamics damping="0.2" friction="0.05"/>
    </joint>

    <link name="${prefix}wrist_pitch_link">
      <visual>
        <geometry>
          <sphere radius="${wrist_radius}"/>
        </geometry>
        <material name="${prefix}arm_blue"/>
      </visual>
      <collision>
        <geometry>
          <sphere radius="${wrist_radius}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.5"/>
        <inertia ixx="0.0003" ixy="0" ixz="0" iyy="0.0003" iyz="0" izz="0.0003"/>
      </inertial>
    </link>

    <!-- ==================== WRIST ROLL (Joint 6) ==================== -->
    <joint name="${prefix}wrist_roll_joint" type="revolute">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <parent link="${prefix}wrist_pitch_link"/>
      <child link="${prefix}wrist_roll_link"/>
      <axis xyz="0 0 1"/>
      <limit lower="${-pi}" upper="${pi}" effort="20.0" velocity="2.5"/>
      <dynamics damping="0.1" friction="0.05"/>
    </joint>

    <link name="${prefix}wrist_roll_link">
      <visual>
        <origin xyz="0 0 ${-wrist_length/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${wrist_radius}" length="${wrist_length}"/>
        </geometry>
        <material name="${prefix}arm_dark_grey"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${-wrist_length/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${wrist_radius}" length="${wrist_length}"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 ${-wrist_length/2}" rpy="0 0 0"/>
        <mass value="0.3"/>
        <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0001"/>
      </inertial>
    </link>

    <!-- Tool center point (end effector mounting point) -->
    <joint name="${prefix}tool0_joint" type="fixed">
      <origin xyz="0 0 ${-wrist_length}" rpy="0 0 0"/>
      <parent link="${prefix}wrist_roll_link"/>
      <child link="${prefix}tool0"/>
    </joint>

    <link name="${prefix}tool0"/>

  </xacro:macro>
</robot>
